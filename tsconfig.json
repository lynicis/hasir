{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": ["packages/*/src"],
  "exclude": ["node_modules", "apps", "deploy", "docker", "proto"]
}
