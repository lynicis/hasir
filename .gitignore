# Unified gitignore for the hasir monorepo.
# Source repos each had a .gitignore; this is the consolidated set with the
# reasons kept inline so future maintainers know why each entry is here.

# ---- Node / Bun / Next.js ----
node_modules/
.next/
.turbo/
.tsbuildinfo
*.tsbuildinfo
bun.lock.original
junit.xml
coverage/
.npmrc.local

# ---- Go ----
# Per-service binaries carry the service name (e.g. apps/api/api). The rule
# `/*/api` would be too broad; instead each Go service ignores its own binary.
/api
/apps/*/api
/apps/*/api.exe
*.test
*.out
coverage.txt
/repos/
/sdk/

# ---- buf generated code ----
# Generated code is NOT committed (see ADR-0003). Keep these out of git so a
# stale generated tree never lands in a PR.
proto/gen/
**/gen/go/
**/gen/ts/

# ---- Helm bundled dependencies ----
# Regenerated by `helm dependency update`. Do not commit the tgz.
deploy/helm/**/charts/*.tgz
deploy/helm/**/charts/**/*.tgz

# ---- Local runtime artifacts that must never be committed ----
.env
.env.local
.env.*.local
config.json
ssh_host_key
*.pem
*.key
!**/*.pem.example

# ---- Certbot / nginx runtime state (carried from docker-images repo) ----
docker/shared/certbot/conf/
docker/shared/certbot/www/

# ---- IDE / editor / agent state ----
.idea/
.vscode/*
!.vscode/extensions.json
*.code-workspace
.DS_Store
.claude/
.opencode/
.gitnexus/
.omo/
.playwright-mcp/*
# ^ Agent instruction files are ignored by default. Teams that want to keep
# CLAUDE.md/AGENTS.md tracked should `git add -f` the file once.

# ---- Build / cache ----
dist/
build/
*.log
tmp/

# Turborepo
.turbo

.worktrees/
