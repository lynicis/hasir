{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    "CONTEXT.md",
    "docs/ARCHITECTURE.md",
    "docs/RELEASE.md"
  ],
  "mcp": {
    "postgresql": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://test:test@localhost:5432/test"
      ]
    },
    "nextjs": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "next-devtools-mcp@latest"
      ]
    },
    "gitnexus": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "gitnexus",
        "mcp"
      ]
    }
  }
}
